// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Employee {
  id        String   @id @default(uuid())
  nom     String
  salaire     Int
  type     String    @default("")
}

model Charge {
  id        String   @id @default(uuid())
  nom     String
  montant     Int
}
